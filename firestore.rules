rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function companyMember(companyId) {
      return signedIn() &&
      exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
    }

    // User references (para buscar companyId por UID)
    match /userRefs/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && request.auth.uid == uid;
      allow update, delete: if false;
    }

    match /companies/{companyId} {

      allow create: if signedIn();

      allow read, update: if companyMember(companyId);

      match /users/{userId} {

        allow create: if signedIn() &&
        request.auth.uid == userId;

        allow read, update: if companyMember(companyId);

      }

      match /vehicles/{vehicleId} {

        allow read, write: if companyMember(companyId);

      }

      match /devices/{deviceId} {

        allow read, write: if companyMember(companyId);

      }

      match /events/{eventId} {

        allow read, write: if companyMember(companyId);

      }

      match /routes/{routeId} {

        allow read, write: if companyMember(companyId);

      }

      match /alerts/{alertId} {

        allow read, write: if companyMember(companyId);

      }

      match /settings/{settingId} {

        allow read, write: if companyMember(companyId);

      }

    }

  }

}
